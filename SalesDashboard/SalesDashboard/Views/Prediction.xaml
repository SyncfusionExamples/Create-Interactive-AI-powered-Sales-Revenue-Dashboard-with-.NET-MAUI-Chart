<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Toolkit.Charts;assembly=Syncfusion.Maui.Toolkit"
             xmlns:local="clr-namespace:SalesDashboard"
             xmlns:gauges="clr-namespace:Syncfusion.Maui.Gauges;assembly=Syncfusion.Maui.Gauges"
             xmlns:dataGrid="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             x:Class="SalesDashboard.Prediction">

    <ContentView.Resources>
        <Style TargetType="dataGrid:DataGridCell">
            <Setter Property="TextColor" Value="#7E7E7E"/>
        </Style>

        <Style TargetType="dataGrid:SfDataGridHeaderLabel">
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="HorizontalTextAlignment" Value="Center"/>
        </Style>

    </ContentView.Resources>

    <ScrollView>
        <Grid RowDefinitions="1.5*,3.5*,2*,3*" ColumnDefinitions="*,*" ColumnSpacing="15" RowSpacing="15">

            <Border Grid.Row="0" Grid.ColumnSpan="2" StrokeThickness="1" Stroke="LightGray" Padding="10">
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="15">

                    <!-- Predicted Revenue -->
                    <VerticalStackLayout Grid.Column="0"  Margin="10,0,0,0">
                        <Label Text="Predicted Revenue" FontAttributes="Bold" FontSize="16" />
                        <Label Text="{Binding PredictedTotalRevenue, StringFormat='${0:N0}'}" Margin="20,15,0,0"
                                   FontSize="22" FontAttributes="Bold" TextColor="#4CAF50" />
                    </VerticalStackLayout>

                    <!-- Prediction Period -->
                    <VerticalStackLayout Grid.Column="1" >
                        <Label Text="Prediction Period" FontAttributes="Bold" FontSize="16"/>
                        <Label Margin="0,15,0,0">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span  Text="{Binding PredictionPeriod.StartDate, StringFormat='{0:dd MMM, yyyy}'}" />
                                    <Span Text=" to " FontAttributes="Bold"/>
                                    <Span Text="{Binding PredictionPeriod.EndDate, StringFormat='{0:dd MMM, yyyy}'}" />
                                </FormattedString>
                            </Label.FormattedText>
                            <Label.FontSize>19</Label.FontSize>
                        </Label>
                    </VerticalStackLayout>

                    <!-- Confidence Level -->
                    <VerticalStackLayout Grid.Column="2">
                        <Label Text="Average Confidence" FontAttributes="Bold" FontSize="16" />
                        <gauges:SfRadialGauge HeightRequest="80" WidthRequest="80" Background="Transparent"
                                                  HorizontalOptions="Start" Margin="20,0,0,0">
                            <gauges:SfRadialGauge.Axes>
                                <gauges:RadialAxis Minimum="0" Maximum="100" ShowLabels="False" ShowTicks="False">
                                    <gauges:RadialAxis.Pointers>
                                        <gauges:NeedlePointer Value="{Binding ConfidenceAverage}" NeedleLength="0.6" NeedleFill="#2196F3" />
                                        <gauges:RangePointer Value="{Binding ConfidenceAverage}" PointerWidth="10" EnableAnimation="True">
                                            <gauges:RangePointer.GradientStops>
                                                <gauges:GaugeGradientStop Value="0" Color="#F44336" />
                                                <gauges:GaugeGradientStop Value="50" Color="#FFC107" />
                                                <gauges:GaugeGradientStop Value="100" Color="#4CAF50" />
                                            </gauges:RangePointer.GradientStops>
                                        </gauges:RangePointer>
                                    </gauges:RadialAxis.Pointers>
                                </gauges:RadialAxis>
                            </gauges:SfRadialGauge.Axes>
                        </gauges:SfRadialGauge>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <chart:SfCartesianChart Grid.Row="1" Grid.ColumnSpan="2">

                <chart:SfCartesianChart.Title>
                    <Label Text="Sales Forecast" FontAttributes="Bold" FontSize="16" Margin="10,0,0,10" />
                </chart:SfCartesianChart.Title>

                <chart:SfCartesianChart.XAxes>
                    <chart:DateTimeAxis IntervalType="Days" ShowMajorGridLines="False" 
                                        Minimum="{Binding StartDate}" Maximum="{Binding EndDate}"/>
                </chart:SfCartesianChart.XAxes>
                
                <chart:SfCartesianChart.YAxes>
                    <chart:NumericalAxis />
                </chart:SfCartesianChart.YAxes>
                
                <chart:SfCartesianChart.Series>
                    <chart:LineSeries XBindingPath="Date" YBindingPath="PredictedRevenue" Label="Predicted Revenue"
                                                        ItemsSource="{Binding Predictions}" EnableTooltip="False"
                                                        Fill="#4CAF50" StrokeWidth="3" />
                    <chart:LineSeries XBindingPath="Date" YBindingPath="LowerBound"  Label="Lower Bound"
                                                        ItemsSource="{Binding Predictions}" EnableTooltip="False"
                                                        Fill="#E0E0E0" StrokeWidth="2" StrokeDashArray="5,5" />
                    <chart:LineSeries XBindingPath="Date" YBindingPath="UpperBound" Label="Upper Bound"
                                                        ItemsSource="{Binding Predictions}" EnableTooltip="False"
                                                        Fill="#E0E0E0" StrokeWidth="2" StrokeDashArray="5,5" />
                </chart:SfCartesianChart.Series>

                <chart:SfCartesianChart.Legend>
                    <chart:ChartLegend>
                    </chart:ChartLegend>
                </chart:SfCartesianChart.Legend>

            </chart:SfCartesianChart>

            <Border Grid.Row="2" Grid.ColumnSpan="2" StrokeThickness="1" Stroke="LightGray" Padding="10">
                <ScrollView HorizontalScrollBarVisibility="Always" VerticalScrollBarVisibility="Always">
                    <VerticalStackLayout>
                        <Label Text="AI Insights" FontAttributes="Bold" FontSize="16" Margin="10,0,0,10" />
                        <Label Text="{Binding InsightsExplanation}" TextType="Html" />
                    </VerticalStackLayout>
                </ScrollView>
            </Border>

            <VerticalStackLayout Grid.Row="3" Grid.ColumnSpan="2">
                <Label Text="Detailed Predictions" FontAttributes="Bold" FontSize="16" Margin="10,0,0,10" />
                <dataGrid:SfDataGrid ItemsSource="{Binding Predictions}" 
                                GridLinesVisibility="Both" AutoGenerateColumnsMode="None"
                                HeaderGridLinesVisibility="Both"
                                HeightRequest="300">
                    <dataGrid:SfDataGrid.Columns>
                        <dataGrid:DataGridTextColumn HeaderText="Date" MappingName="Date" Format="d"/>
                        <dataGrid:DataGridTextColumn HeaderText="Predicted Revenue" MappingName="PredictedRevenue" Format="$#.##" />
                        <dataGrid:DataGridTextColumn HeaderText="Lower Bound" MappingName="LowerBound" Format="$#.##" />
                        <dataGrid:DataGridTextColumn HeaderText="Upper Bound" MappingName="UpperBound" Format="$#.##" />
                        <dataGrid:DataGridTextColumn HeaderText="Confidence" MappingName="Confidence" Format="P0" />
                        <!--<dataGrid:DataGridCheckBoxColumn HeaderText="Anomaly" MappingName="IsAnomaly" />-->

                        <dataGrid:DataGridTextColumn HeaderText="Product ID" MappingName="ProductId" />
                        <dataGrid:DataGridTextColumn HeaderText="Region ID" MappingName="RegionId" />
                        <dataGrid:DataGridTextColumn HeaderText="Explanation" MappingName="Explanation" HeaderTextAlignment="Center"
                                                   LineBreakMode="WordWrap" ColumnWidthMode="LastColumnFill"/>
                    </dataGrid:SfDataGrid.Columns>
                </dataGrid:SfDataGrid>
            </VerticalStackLayout>

            <core:SfBusyIndicator Grid.Row="0" Grid.ColumnSpan="2" Grid.RowSpan="4" IsVisible="{Binding IsBusy}" x:Name="busyIndicator"
                       IsRunning="{Binding IsBusy}" AnimationType="Cupertino" SizeFactor="0.8"/>

        </Grid>
    </ScrollView>

</ContentView>
