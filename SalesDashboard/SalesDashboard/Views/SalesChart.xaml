<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Toolkit.Charts;assembly=Syncfusion.Maui.Toolkit"
             xmlns:dataGrid="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             xmlns:comboBox="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
             xmlns:sfButton="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
             xmlns:popup ="clr-namespace:Syncfusion.Maui.Popup;assembly=Syncfusion.Maui.Popup"
             xmlns:aiassistview="clr-namespace:Syncfusion.Maui.AIAssistView;assembly=Syncfusion.Maui.AIAssistView"
             xmlns:local="clr-namespace:SalesDashboard"
             x:Class="SalesDashboard.SalesChart">

    <ContentView.Resources>
        
        <Style TargetType="dataGrid:DataGridCell">
            <Setter Property="TextColor" Value="#7E7E7E"/>
        </Style>

        <Style TargetType="dataGrid:SfDataGridHeaderLabel">
            <Setter Property="Background" Value="#F9FAFB" />
        </Style>
        
    </ContentView.Resources>

    <Grid RowDefinitions="8*,2*" ColumnDefinitions="8*,2*">

        <ScrollView Grid.RowSpan="2" Grid.ColumnSpan="2">
            <Grid RowDefinitions="1*,3.49*,0.01*,2.49*,3*" ColumnDefinitions="5*,0.01*,4.99*">

                <Grid Grid.Row="0" Grid.ColumnSpan="3" Margin="0,5,0,0" ColumnDefinitions="5.5*,4.5*" >

                    <Grid Grid.Column="0" ColumnDefinitions="3,2.3*,2.3*,2.3*" ColumnSpacing="10">
                        <!-- Total Revenue Card -->
                        <Border Grid.Column="0" StrokeThickness="1" Stroke="LightGray" StrokeShape="RoundRectangle 8" Padding="10">
                            <VerticalStackLayout>
                                <Label Text="Total Revenue" FontAttributes="Bold" FontSize="14" />
                                <Label Text="{Binding TotalRevenue, StringFormat='${0:N0}'}" FontSize="20" FontAttributes="Bold" TextColor="#4CAF50" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Total Profit Card -->
                        <Border Grid.Column="1" StrokeThickness="1" Stroke="LightGray" StrokeShape="RoundRectangle 8" Padding="10">
                            <VerticalStackLayout>
                                <Label Text="Total Profit" FontAttributes="Bold" FontSize="14" />
                                <Label Text="{Binding TotalProfit, StringFormat='${0:N0}'}" FontSize="20" FontAttributes="Bold" TextColor="#2196F3" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Profit Margin Card -->
                        <Border Grid.Column="2" StrokeThickness="1" Stroke="LightGray" StrokeShape="RoundRectangle 8" Padding="10">
                            <VerticalStackLayout>
                                <Label Text="Profit Margin" FontAttributes="Bold" FontSize="14" />
                                <Label Text="{Binding ProfitMargin, StringFormat='{0:N1}%'}" FontSize="20" FontAttributes="Bold" TextColor="#FF9800" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Growth Rate Card -->
                        <Border Grid.Column="3" StrokeThickness="1" Stroke="LightGray" StrokeShape="RoundRectangle 8" Padding="10">
                            <VerticalStackLayout>
                                <Label Text="Growth Rate" FontAttributes="Bold" FontSize="14" />
                                <Label Text="{Binding GrowthRate, StringFormat='{0:N1}%'}" FontSize="20" FontAttributes="Bold" TextColor="#9C27B0" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                        <comboBox:SfComboBox Grid.Column="1" Margin="6,6,10,6" x:Name="periodSelection"  ItemsSource="{Binding DateRanges}" 
         DisplayMemberPath="DisplayText"  DropDownIconColor="#333333" HorizontalOptions="End"
         WidthRequest="{OnPlatform Android=150, iOS=150, Default=160}" SelectionChanged="periodSelection_SelectionChanged"
         Background="#FFFFFF" DropDownStroke="#D1D5DB" HorizontalTextAlignment="Center" Stroke="#D1D5DB"
         FontSize="16" IsClearButtonVisible="False" SelectedIndex="0" TextColor="#333333"/>

                </Grid>

                <chart:SfCartesianChart Grid.Row="1" Grid.ColumnSpan="3" Margin="10">

                    <chart:SfCartesianChart.Title>
                        <Label Text="Revenue Trend" FontAttributes="Bold" FontSize="16" Margin="10,0,0,10" />
                    </chart:SfCartesianChart.Title>

                    <chart:SfCartesianChart.XAxes>
                        <chart:DateTimeAxis IntervalType="Days" ShowMajorGridLines="False" />
                    </chart:SfCartesianChart.XAxes>
                    <chart:SfCartesianChart.YAxes>
                        <chart:NumericalAxis />
                    </chart:SfCartesianChart.YAxes>
                    <chart:SfCartesianChart.Series>
                        <chart:AreaSeries XBindingPath="Date" YBindingPath="Revenue" 
                                     ItemsSource="{Binding SalesData}" EnableTooltip="True"
                                     Fill="#8028A7F1" Stroke="#2196F3" StrokeWidth="2" />
                    </chart:SfCartesianChart.Series>
                </chart:SfCartesianChart>

                <HorizontalStackLayout HeightRequest="1" Background="#C4C7C5" Grid.Row="2" Grid.ColumnSpan="3"/>

                <chart:SfCartesianChart Grid.Row="3" Grid.Column="0" Margin="10">

                    <chart:SfCartesianChart.Title>
                        <Label Text="Quantity Sold" FontAttributes="Bold" FontSize="16" Margin="10,0,0,10" />
                    </chart:SfCartesianChart.Title>

                    <chart:SfCartesianChart.XAxes>
                        <chart:DateTimeAxis IntervalType="Days" ShowMajorGridLines="False" />
                    </chart:SfCartesianChart.XAxes>
                    <chart:SfCartesianChart.YAxes>
                        <chart:NumericalAxis />
                    </chart:SfCartesianChart.YAxes>
                    <chart:SfCartesianChart.Series>
                        <chart:ColumnSeries XBindingPath="Date" YBindingPath="Quantity" 
                                      ItemsSource="{Binding SalesData}" EnableTooltip="True"
                                      Fill="#4CAF50" />
                    </chart:SfCartesianChart.Series>
                </chart:SfCartesianChart>

                <VerticalStackLayout Background="#C4C7C5" Grid.Row="3" WidthRequest="1" Grid.Column="1"/>

                <chart:SfCartesianChart Grid.Row="3" Grid.Column="2" Margin="10">

                    <chart:SfCartesianChart.Title>
                        <Label Text="Profit Margin %" FontAttributes="Bold" FontSize="16" Margin="10,0,0,10" />
                    </chart:SfCartesianChart.Title>

                    <chart:SfCartesianChart.XAxes>
                        <chart:DateTimeAxis IntervalType="Days" ShowMajorGridLines="False" />
                    </chart:SfCartesianChart.XAxes>
                    <chart:SfCartesianChart.YAxes>
                        <chart:NumericalAxis Minimum="10" Maximum="100"/>
                    </chart:SfCartesianChart.YAxes>
                    <chart:SfCartesianChart.Series>
                        <chart:LineSeries XBindingPath="Date" YBindingPath="ProfitMargin" 
                                    ItemsSource="{Binding SalesData}" EnableTooltip="True"
                                    Fill="#FF9800" StrokeWidth="2" />
                    </chart:SfCartesianChart.Series>
                </chart:SfCartesianChart>

                <VerticalStackLayout Grid.Row="4" Grid.ColumnSpan="3">
                    <Label Text="Sales Data" FontAttributes="Bold" FontSize="16" Margin="10,0,0,10" />
                    <dataGrid:SfDataGrid ItemsSource="{Binding FilteredSalesData}" 
                AutoGenerateColumnsMode="None" SortingMode="Single" ColumnWidthMode="FitByCell"
                GridLinesVisibility="Both" HeaderGridLinesVisibility="Both">
                        <dataGrid:SfDataGrid.Columns>
                            <dataGrid:DataGridTextColumn HeaderText="Date" MappingName="Date" Format="d" HeaderTextAlignment="Start"/>
                            <dataGrid:DataGridTextColumn HeaderText="Product" MappingName="ProductName" HeaderTextAlignment="Start" />
                            <dataGrid:DataGridTextColumn HeaderText="Region" MappingName="RegionName" HeaderTextAlignment="Start" ColumnWidthMode="LastColumnFill"/>
                            <dataGrid:DataGridTextColumn HeaderText="Quantity" MappingName="Quantity" HeaderTextAlignment="Start"/>
                            <dataGrid:DataGridTextColumn HeaderText="Revenue" MappingName="Revenue" Format="C2" HeaderTextAlignment="Start"/>
                            <dataGrid:DataGridTextColumn HeaderText="Cost" MappingName="Cost" Format="C2" HeaderTextAlignment="Start"/>
                            <dataGrid:DataGridTextColumn HeaderText="Profit" MappingName="Profit" Format="C2" HeaderTextAlignment="Start"/>
                            <dataGrid:DataGridTextColumn HeaderText="Profit %" MappingName="ProfitMargin" Format="P2" HeaderTextAlignment="Start"/>
                        </dataGrid:SfDataGrid.Columns>
                    </dataGrid:SfDataGrid>
                </VerticalStackLayout>

            </Grid>

        </ScrollView>


        <StackLayout Grid.Row="1" Grid.Column="1" VerticalOptions="Start" Margin="0,0,50,0">
            
            <sfButton:SfButton x:Name="clickToShowPopup" ShowIcon="True" Background="#0050EB" CornerRadius="8"
               ImageSize="50" HorizontalOptions="End" ImageSource="ai_button.png" TextColor="White">

                <sfButton:SfButton.GestureRecognizers>
                    <PointerGestureRecognizer PointerExited="PointerGestureRecognizer_PointerExited"
                        PointerMoved="PointerGestureRecognizer_PointerMoved" PointerReleased="PointerGestureRecognizer_PointerReleased"
                        PointerPressed="PointerGestureRecognizer_PointerPressed"/>
                </sfButton:SfButton.GestureRecognizers>

            </sfButton:SfButton>

            <popup:SfPopup x:Name="popup" ShowHeader="False" AnimationMode="SlideOnRight" 
                           WidthRequest="800" HeightRequest="400">
                <popup:SfPopup.ContentTemplate>
                    <DataTemplate>
                        
                        <ScrollView HorizontalScrollBarVisibility="Always" VerticalScrollBarVisibility="Always">
                            <aiassistview:SfAIAssistView IsVisible="{Binding ShowAssistView, Mode=TwoWay}"
                              x:Name="aiAssistView" HorizontalOptions="Fill" Request ="aiAssistView_Request" 
                             ShowHeader="True" AssistItems="{Binding Messages}">
                                <aiassistview:SfAIAssistView.HeaderTemplate>
                                    <DataTemplate>
                                        <Label Text="How may I help you?" FontAttributes="Bold" Padding="0,20,0,0"
                                    LineBreakMode="WordWrap" FontSize="14" HorizontalOptions="Center"/>
                                    </DataTemplate>
                                </aiassistview:SfAIAssistView.HeaderTemplate>
                                <aiassistview:SfAIAssistView.Shadow>
                                    <Shadow Brush="Black"  Opacity="0.5" Offset="4,4" Radius="5"/>
                                </aiassistview:SfAIAssistView.Shadow>
                            </aiassistview:SfAIAssistView>
                        </ScrollView>
                        
                    </DataTemplate>
                </popup:SfPopup.ContentTemplate>
            </popup:SfPopup>
        </StackLayout>

    </Grid>

</ContentView>