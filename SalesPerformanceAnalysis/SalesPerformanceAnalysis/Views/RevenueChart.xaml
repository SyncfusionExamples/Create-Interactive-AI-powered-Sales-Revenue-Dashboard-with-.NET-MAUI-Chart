<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Toolkit.Charts;assembly=Syncfusion.Maui.Toolkit"
             xmlns:local="clr-namespace:SalesPerformanceAnalysis"
             xmlns:gauges="clr-namespace:Syncfusion.Maui.Gauges;assembly=Syncfusion.Maui.Gauges"
             xmlns:dataGrid="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             x:Class="SalesPerformanceAnalysis.RevenueChart">

    <ScrollView Grid.Row="1">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="15" RowSpacing="15">
                <!-- Prediction Summary -->
                <Border Grid.Row="0" Grid.ColumnSpan="2" StrokeThickness="1" Stroke="LightGray" StrokeShape="RoundRectangle 8" Padding="10">
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="15">
                        <!-- Predicted Revenue -->
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Predicted Revenue" FontAttributes="Bold" FontSize="14" />
                            <Label Text="{Binding PredictedTotalRevenue, StringFormat='${0:N0}'}" FontSize="18" FontAttributes="Bold" TextColor="#4CAF50" />
                        </VerticalStackLayout>

                        <!-- Prediction Period -->
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Prediction Period" FontAttributes="Bold" FontSize="14" />
                            <Label>
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding PredictionPeriod.StartDate, StringFormat='{0:d}'}" />
                                        <Span Text=" to " />
                                        <Span Text="{Binding PredictionPeriod.EndDate, StringFormat='{0:d}'}" />
                                    </FormattedString>
                                </Label.FormattedText>
                                <Label.FontSize>14</Label.FontSize>
                            </Label>
                        </VerticalStackLayout>

                        <!-- Confidence Level -->
                        <VerticalStackLayout Grid.Column="2">
                            <Label Text="Average Confidence" FontAttributes="Bold" FontSize="14" />
                            <gauges:SfRadialGauge HeightRequest="80" WidthRequest="80" HorizontalOptions="Start">
                                <gauges:SfRadialGauge.Axes>
                                    <gauges:RadialAxis Minimum="0" Maximum="100" ShowLabels="False" ShowTicks="False">
                                        <gauges:RadialAxis.Pointers>
                                            <gauges:NeedlePointer Value="{Binding ConfidenceAverage}" NeedleLength="0.6" NeedleFill="#2196F3" />
                                            <gauges:RangePointer Value="{Binding ConfidenceAverage}" PointerWidth="10" EnableAnimation="True">
                                                <gauges:RangePointer.GradientStops>
                                                    <gauges:GaugeGradientStop Value="0" Color="#F44336" />
                                                    <gauges:GaugeGradientStop Value="50" Color="#FFC107" />
                                                    <gauges:GaugeGradientStop Value="100" Color="#4CAF50" />
                                                </gauges:RangePointer.GradientStops>
                                            </gauges:RangePointer>
                                        </gauges:RadialAxis.Pointers>
                                    </gauges:RadialAxis>
                                </gauges:SfRadialGauge.Axes>
                            </gauges:SfRadialGauge>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Prediction Chart -->
                <Border Grid.Row="1" Grid.ColumnSpan="2" StrokeThickness="1" Stroke="LightGray" StrokeShape="RoundRectangle 8" Padding="10">
                    <VerticalStackLayout>
                        <Label Text="Sales Forecast" FontAttributes="Bold" FontSize="16" Margin="10,0,0,10" />
                        <chart:SfCartesianChart HeightRequest="250">
                            <chart:SfCartesianChart.XAxes>
                                <chart:DateTimeAxis IntervalType="Days" ShowMajorGridLines="False" />
                            </chart:SfCartesianChart.XAxes>
                            <chart:SfCartesianChart.YAxes>
                                <chart:NumericalAxis />
                            </chart:SfCartesianChart.YAxes>
                            <chart:SfCartesianChart.Series>
                                <chart:LineSeries XBindingPath="Date" YBindingPath="PredictedRevenue" 
                                                        ItemsSource="{Binding Predictions}" EnableTooltip="True"
                                                        Fill="#4CAF50" StrokeWidth="3" />
                                <chart:LineSeries XBindingPath="Date" YBindingPath="LowerBound" 
                                                        ItemsSource="{Binding Predictions}" EnableTooltip="True"
                                                        Fill="#E0E0E0" StrokeWidth="2" StrokeDashArray="5,5" />
                                <chart:LineSeries XBindingPath="Date" YBindingPath="UpperBound" 
                                                        ItemsSource="{Binding Predictions}" EnableTooltip="True"
                                                        Fill="#E0E0E0" StrokeWidth="2" StrokeDashArray="5,5" />
                            </chart:SfCartesianChart.Series>
                            
                            <chart:SfCartesianChart.Legend>
                                <chart:ChartLegend>
                                    <chart:ChartLegend.ItemTemplate>
                                        <DataTemplate>
                                            <HorizontalStackLayout Spacing="5">
                                                <BoxView WidthRequest="10" HeightRequest="10" Color="{Binding IconBrush}" VerticalOptions="Center" />
                                                <Label Text="{Binding Label}" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </DataTemplate>
                                    </chart:ChartLegend.ItemTemplate>
                                </chart:ChartLegend>
                            </chart:SfCartesianChart.Legend>
                            
                        </chart:SfCartesianChart>
                    </VerticalStackLayout>
                </Border>

                <!-- AI Insights -->
                <Border Grid.Row="2" Grid.ColumnSpan="2" StrokeThickness="1" Stroke="LightGray" StrokeShape="RoundRectangle 8" Padding="10">
                    <VerticalStackLayout>
                        <Label Text="AI Insights" FontAttributes="Bold" FontSize="16" Margin="10,0,0,10" />
                        <Label Text="{Binding InsightsExplanation}" TextType="Html" />
                    </VerticalStackLayout>
                </Border>

                <!-- Predictions Data Grid -->
                <Border Grid.Row="3" Grid.ColumnSpan="2" StrokeThickness="1" Stroke="LightGray" StrokeShape="RoundRectangle 8" Padding="10">
                    <VerticalStackLayout>
                        <Label Text="Detailed Predictions" FontAttributes="Bold" FontSize="16" Margin="10,0,0,10" />
                        <dataGrid:SfDataGrid ItemsSource="{Binding Predictions}" 
                                                AutoGenerateColumnsMode="None" 
                                                ColumnWidthMode="FitByHeader"
                                                GridLinesVisibility="Both"
                                                HeaderGridLinesVisibility="Both"
                                                HeightRequest="300">
                            <dataGrid:SfDataGrid.Columns>
                                <dataGrid:DataGridTextColumn HeaderText="Date" MappingName="Date" Format="d" />
                                <dataGrid:DataGridTextColumn HeaderText="Predicted Revenue" MappingName="PredictedRevenue" Format="C2" />
                                <dataGrid:DataGridTextColumn HeaderText="Lower Bound" MappingName="LowerBound" Format="C2" />
                                <dataGrid:DataGridTextColumn HeaderText="Upper Bound" MappingName="UpperBound" Format="C2" />
                                <dataGrid:DataGridTextColumn HeaderText="Confidence" MappingName="Confidence" Format="P0" />
                                <dataGrid:DataGridCheckBoxColumn HeaderText="Anomaly" MappingName="IsAnomaly" />
                            </dataGrid:SfDataGrid.Columns>
                        </dataGrid:SfDataGrid>
                    </VerticalStackLayout>
                </Border>
            </Grid>
    </ScrollView>
    

</ContentView>
