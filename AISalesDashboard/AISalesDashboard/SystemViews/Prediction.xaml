<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AISalesDashboard"
             xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             x:Class="AISalesDashboard.Prediction">

    <ScrollView x:DataType="local:PredictionViewModel" Background="#F7F2FB">
        <Grid RowDefinitions="0.3*,9.7*" RowSpacing="5" Padding="10">

            <local:CustomBorder Grid.Row="0">
                <local:CustomBorder.Content>
                    <local:PredictionSummary/>
                </local:CustomBorder.Content>
            </local:CustomBorder>

            <local:CustomBorder Grid.Row="1">
                <local:CustomBorder.Content>
                    <local:PredictionDetails/>
                </local:CustomBorder.Content>
            </local:CustomBorder>

            <core:SfBusyIndicator Grid.Row="0" Grid.RowSpan="2" IsVisible="{Binding IsBusy}" x:Name="busyIndicator"
                       IsRunning="{Binding IsBusy}" AnimationType="Cupertino" SizeFactor="0.8"/>

        </Grid>
    </ScrollView>

</ContentView>