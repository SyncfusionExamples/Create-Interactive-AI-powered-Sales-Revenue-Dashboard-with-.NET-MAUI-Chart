<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AISalesDashboard.AndroidUI"
             xmlns:local="clr-namespace:AISalesDashboard"
             xmlns:tabView="clr-namespace:Syncfusion.Maui.TabView;assembly=Syncfusion.Maui.TabView"
             xmlns:sfButton="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
             xmlns:aiassistview="clr-namespace:Syncfusion.Maui.AIAssistView;assembly=Syncfusion.Maui.AIAssistView">

    <Grid RowDefinitions="8*,2*" ColumnDefinitions="7*,3*">

        <tabView:SfTabView Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="2" x:Name="tabView" TabWidthMode="Default" TabBarPlacement="Bottom" SelectedIndex="0"
                   TabBarHeight="60" IndicatorPlacement="Fill" IndicatorBackground="#F5F5F5" TabBarBackground="#6750A4" IndicatorWidthMode="Fit" IndicatorCornerRadius="20" SelectionChanged="tabView_SelectionChanged">
            <tabView:SfTabItem x:Name="homeView" Header="&#xe88a;" FontFamily="MaterialSymbolOutlined" FontSize="25" TextColor="#6750A4"/>

            <tabView:SfTabItem x:Name="productsView" Header="&#xf569;" FontFamily="MaterialSymbolOutlined" FontSize="25" TextColor="#FFFFFF"/>

            <tabView:SfTabItem x:Name="ordersView" Header="&#xe8cc;" FontFamily="MaterialSymbolOutlined" FontSize="25" TextColor="#FFFFFF"/>

            <tabView:SfTabItem x:Name="predictionsView" Header="&#xe26b;" FontFamily="MaterialSymbolOutlined" FontSize="25" TextColor="#FFFFFF"/>

        </tabView:SfTabView>

        <ContentView x:Name="assistviewContent" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2" IsVisible="False">
            <Grid RowDefinitions="1*,9*">

                <Grid Grid.Row="0" ColumnDefinitions="1*,1*,8*" Background="#6750A4" x:Name="assistViewHeader"
                Padding="10" ColumnSpacing="20">
                    <sfButton:SfButton Text="&#xf1e6;" TextColor="#FFFFFF" FontFamily="MaterialIcons" FontSize="27" WidthRequest="70" HeightRequest="40" Grid.Column="0" Clicked="SfButton_Clicked" Margin="20,0,0,0"/>
                    <Border Background="#FFFBFE" Stroke="#6750A4" StrokeShape="RoundRectangle 45" Grid.Column="1" WidthRequest="50" HeightRequest="50">
                        <Image Source="ai_icon1.png" WidthRequest="20" HeightRequest="20"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="2" VerticalOptions="Center">
                        <Label Text="Assistant" TextColor="#FFFFFF"
                        FontSize="14" FontFamily="RobotoMedium"/>
                        <Label Text="How may I help you?" TextColor="#FFFFFF"
                    FontSize="14" FontFamily="RobotoMedium"/>
                    </VerticalStackLayout>
                </Grid>

                <ScrollView Grid.Row="1">
                    <aiassistview:SfAIAssistView IsVisible="{Binding ShowAssistView}"
     x:Name="aiAssistView" HorizontalOptions="Fill" Request ="aiAssistView_Request" AssistItems="{Binding Messages}" ShowHeader="True" Suggestions="{Binding Suggestions}">

                        <aiassistview:SfAIAssistView.HeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="5">
                                    <Label Text="Here some of prompt suggestions" TextColor="#1C1B1F" FontSize="14" VerticalOptions="Center" HorizontalOptions="Center"/>
                                </Grid>
                            </DataTemplate>
                        </aiassistview:SfAIAssistView.HeaderTemplate>

                        <aiassistview:SfAIAssistView.SuggestionTemplate>
                            <DataTemplate x:DataType="aiassistview:AssistSuggestion">
                                <Border HeightRequest="40" 
                                 BackgroundColor="#F7F2FB"
                                 Stroke="Transparent" Margin="0,0,0,5"
                                 StrokeShape="RoundRectangle 8"
                                 Padding="12,0,12,0">
                                    <Border.Shadow>
                                        <Shadow Brush="#26000000" Offset="0,2" Radius="1.5" Opacity="1"/>
                                    </Border.Shadow>
                                    <Label Text="{Binding Text}" 
                                     FontSize="16"
                                     HorizontalTextAlignment="Center"
                                     HorizontalOptions="Center" VerticalTextAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </aiassistview:SfAIAssistView.SuggestionTemplate>
                    </aiassistview:SfAIAssistView>
                </ScrollView>

            </Grid>
        </ContentView>

        <sfButton:SfButton Grid.Row="1" Grid.Column="2" x:Name="clickToShowPopup" ShowIcon="True" Background="#6750A4" WidthRequest="50" CornerRadius="50"
            ImageSize="20" HorizontalOptions="End" ImageAlignment="Default" ImageSource="ai_icon.png" HeightRequest="50"
            Clicked="clickToShowPopup_Clicked" Margin="0,0,20,100" IsVisible="True">
        </sfButton:SfButton>

    </Grid>

</ContentView>