<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AISalesDashboard"
             x:Class="AISalesDashboard.ProductDetailsAndroid">

    <ScrollView Background="#F7F2FB" Padding="10">
        <Grid RowDefinitions="2*, 1*, 7*" RowSpacing="10">
      
            <local:CustomBorder Grid.Row="0">
                <local:CustomBorder.Content>
                    <local:ProductChart/>
                </local:CustomBorder.Content>
            </local:CustomBorder>

            <local:CustomBorder Grid.Row="1">
                <local:CustomBorder.Content>
                    <local:ProductSalesRegion/>
                </local:CustomBorder.Content>
            </local:CustomBorder>

            <local:CustomBorder Grid.Row="2">
                <local:CustomBorder.Content>
                    <local:ProductList/>
                </local:CustomBorder.Content>
            </local:CustomBorder>

        </Grid>

    </ScrollView>

</ContentView>