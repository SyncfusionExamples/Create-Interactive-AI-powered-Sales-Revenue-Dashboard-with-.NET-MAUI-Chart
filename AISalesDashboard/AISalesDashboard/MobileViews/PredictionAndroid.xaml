<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             xmlns:local="clr-namespace:AISalesDashboard"
             xmlns:gauges="clr-namespace:Syncfusion.Maui.Gauges;assembly=Syncfusion.Maui.Gauges"
             xmlns:segmentedControl="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
             xmlns:dataGrid="clr-namespace:Syncfusion.Maui.DataGrid;assembly=Syncfusion.Maui.DataGrid"
             xmlns:core="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
             x:Class="AISalesDashboard.PredictionAndroid">


    <ScrollView Background="#F7F2FB" Padding="5">
        <Grid RowDefinitions="2*, 1*, 5*, 2*" RowSpacing="5">
            <Grid Grid.Row="0" ColumnDefinitions="4*, 6*" ColumnSpacing="5">

                <Border Grid.Column="0" Stroke="#F7F2FB" Background="#FFFBFE" StrokeShape="RoundRectangle 8" Padding="7">

                    <Grid Grid.Column="0" ColumnDefinitions="2*, 8*" ColumnSpacing="5">
                        <Image Source="total_revenue.png" WidthRequest="28" HeightRequest="30"/>
                        <VerticalStackLayout Spacing="2" Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Predicted Revenue" FontSize="12" FontFamily="RobotoMedium" TextColor="#49454F"/>
                            <Label Text="{Binding PredictedTotalRevenue, StringFormat='${0:N0}'}" FontSize="16" FontFamily="RobotoMedium" TextColor="#1C1B1F"/>
                        </VerticalStackLayout>
                    </Grid>

                </Border>

                <Border Grid.Column="1" Stroke="#F7F2FB" Background="#FFFBFE" StrokeShape="RoundRectangle 8" Padding="7">
                    <Grid Grid.Column="2" ColumnDefinitions="2*, 8*">
                        <Image Source="prediction_period.png" WidthRequest="30" HeightRequest="30"/>
                        <VerticalStackLayout Spacing="2" Grid.Column="1" VerticalOptions="Center">
                            <Label Text="Prediction Period" FontSize="12" FontFamily="RobotoMedium" TextColor="#49454F"/>
                            <Label VerticalOptions="Center" FontFamily="RobotoMedium" TextColor="#1C1B1F">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span  Text="{Binding PredictionPeriod.StartDate, StringFormat='{0:dd MMM, yyyy}'}" />
                                        <Span Text=" to "/>
                                        <Span Text="{Binding PredictionPeriod.EndDate, StringFormat='{0:dd MMM, yyyy}'}" />
                                    </FormattedString>
                                </Label.FormattedText>
                                <Label.FontSize>16</Label.FontSize>
                            </Label>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="1" Stroke="#F7F2FB" Background="#FFFBFE" StrokeShape="RoundRectangle 8" Padding="10">
                <VerticalStackLayout>
                    <Label Text="Average Confidence" FontSize="16" HorizontalTextAlignment="Start" FontFamily="RobotoMedium" TextColor="#49454F"/>
                    <gauges:SfRadialGauge Background="Transparent" HeightRequest="200">
                        <gauges:SfRadialGauge.Axes>
                            <gauges:RadialAxis Minimum="0" Maximum="100" ShowLabels="False" ShowTicks="False">
                                <gauges:RadialAxis.AxisLineStyle>
                                    <gauges:RadialLineStyle Thickness="2"/>
                                </gauges:RadialAxis.AxisLineStyle>
                                <gauges:RadialAxis.Pointers>
                                    <gauges:NeedlePointer Value="{Binding ConfidenceAverage}" NeedleLength="0.6" NeedleStartWidth="0.5" NeedleEndWidth="5" NeedleFill="Black" KnobRadius="0.05" KnobFill="{AppThemeBinding Light='Black', Dark='#49454F'}"/>
                                    <gauges:RangePointer Value="{Binding ConfidenceAverage}" PointerWidth="3" EnableAnimation="True" CornerStyle="BothCurve">
                                        <gauges:RangePointer.GradientStops>
                                            <gauges:GaugeGradientStop Value="0" Color="#F44336" />
                                            <gauges:GaugeGradientStop Value="50" Color="#FFC107" />
                                            <gauges:GaugeGradientStop Value="100" Color="#4CAF50" />
                                        </gauges:RangePointer.GradientStops>
                                    </gauges:RangePointer>
                                </gauges:RadialAxis.Pointers>
                            </gauges:RadialAxis>
                        </gauges:SfRadialGauge.Axes>
                    </gauges:SfRadialGauge>
                </VerticalStackLayout>
            </Border>

            <Border Grid.Row="2" Stroke="#F7F2FB" Background="#FFFBFE" StrokeShape="RoundRectangle 8" Padding="10">
                <Grid RowDefinitions="1*, 9*">

                    <Grid ColumnDefinitions="5*,5*" Grid.Row="0">

                        <Label Grid.Column="0" Text="Sales Prediction" FontAttributes="Bold" FontSize="16" VerticalOptions="Center" FontFamily="RobotoMedium" TextColor="#1C1B1F"/>

                        <segmentedControl:SfSegmentedControl x:Name="segmentedControl" x:DataType="local:PredictionViewModel" Grid.Column="1" Margin="5" HorizontalOptions="End" SelectedIndex="0" SelectionChanged="SfSegmentedControl_SelectionChanged" CornerRadius="5" SegmentWidth="50">
                            <segmentedControl:SfSegmentedControl.SelectionIndicatorSettings>
                                <segmentedControl:SelectionIndicatorSettings 
                                    SelectionIndicatorPlacement="Fill"
                                    Background="#6750A4"/>
                            </segmentedControl:SfSegmentedControl.SelectionIndicatorSettings>
                        </segmentedControl:SfSegmentedControl>

                    </Grid>

                    <chart:SfCartesianChart x:Name="chart" x:DataType="local:PredictionViewModel" IsVisible="True" Grid.Row="1" HeightRequest="400" VerticalOptions="Start">

                        <chart:SfCartesianChart.XAxes>
                            <chart:DateTimeAxis IntervalType="Days" ShowMajorGridLines="False" LabelCreated="DateTimeAxis_LabelCreated"
                    Minimum="{Binding StartDate}" Maximum="{Binding EndDate}">
                                <chart:DateTimeAxis.LabelStyle>
                                    <chart:ChartAxisLabelStyle TextColor="#49454F"/>
                                </chart:DateTimeAxis.LabelStyle>
                                <chart:DateTimeAxis.MajorGridLineStyle>
                                    <chart:ChartLineStyle Stroke="#E7E0EC"/>
                                </chart:DateTimeAxis.MajorGridLineStyle>
                            </chart:DateTimeAxis>
                        </chart:SfCartesianChart.XAxes>

                        <chart:SfCartesianChart.YAxes>
                            <chart:NumericalAxis>
                                <chart:NumericalAxis.LabelStyle>
                                    <chart:ChartAxisLabelStyle TextColor="#49454F"/>
                                </chart:NumericalAxis.LabelStyle>
                                <chart:NumericalAxis.MajorGridLineStyle>
                                    <chart:ChartLineStyle Stroke="#E7E0EC"/>
                                </chart:NumericalAxis.MajorGridLineStyle>
                            </chart:NumericalAxis>
                        </chart:SfCartesianChart.YAxes>

                        <chart:LineSeries ItemsSource="{Binding Predictions}" 
                                      XBindingPath="Date" 
                                      YBindingPath="PredictedRevenue" 
                                      Label="Predicted Revenue"
                                      EnableTooltip="False"
                                      Fill="#116DF9" StrokeWidth="2" LegendIcon="SeriesType"/>
                        <chart:LineSeries ItemsSource="{Binding Predictions}" 
                                      XBindingPath="Date" 
                                      YBindingPath="LowerBound"  
                                      Label="Lower Bound" 
                                      EnableTooltip="False"
                                      Fill="#CAC4D0" StrokeWidth="1.5" StrokeDashArray="5,5" LegendIcon="SeriesType"/>
                        <chart:LineSeries ItemsSource="{Binding Predictions}" 
                                      XBindingPath="Date" 
                                      YBindingPath="UpperBound" 
                                      Label="Upper Bound"
                                      Fill="#CAC4D0" 
                                      StrokeWidth="1.5" StrokeDashArray="5,5" LegendIcon="SeriesType"/>

                        <chart:SfCartesianChart.Legend>
                            <chart:ChartLegend Placement="Bottom">
                                <chart:ChartLegend.LabelStyle>
                                    <chart:ChartLegendLabelStyle Margin="0,5" TextColor="#1C1B1F"/>
                                </chart:ChartLegend.LabelStyle>
                            </chart:ChartLegend>
                        </chart:SfCartesianChart.Legend>

                    </chart:SfCartesianChart>

                    <VerticalStackLayout x:Name="dataGrid" IsVisible="False" Grid.Row="1" x:DataType="local:PredictionViewModel">

                        <dataGrid:SfDataGrid ItemsSource="{Binding PredictionPagedItems}" Grid.Row="1"
                            GridLinesVisibility="Both" AutoGenerateColumnsMode="None" DefaultStyle="{StaticResource customStyle}"
                            HeaderGridLinesVisibility="Both">
                            <dataGrid:SfDataGrid.Columns>
                                <dataGrid:DataGridTextColumn HeaderText="Date" MappingName="Date" Format="d" MaximumWidth="100"/>
                                <dataGrid:DataGridTextColumn HeaderText="Predicted Revenue" MappingName="PredictedRevenue" Format="$#.##" MinimumWidth="150"/>
                                <dataGrid:DataGridTextColumn HeaderText="Lower Bound" MappingName="LowerBound" Format="$#.##" MinimumWidth="150"/>
                                <dataGrid:DataGridTextColumn HeaderText="Upper Bound" MappingName="UpperBound" Format="$#.##" MinimumWidth="150"/>
                                <dataGrid:DataGridTextColumn HeaderText="Confidence" MappingName="Confidence" Format="P0" MinimumWidth="150"/>
                                <dataGrid:DataGridTextColumn HeaderText="Product ID" MappingName="ProductId" Format="'#'#" MinimumWidth="150"/>
                                <dataGrid:DataGridTextColumn HeaderText="Region ID" MappingName="RegionId" MinimumWidth="150"/>
                                <dataGrid:DataGridTextColumn HeaderText="Explanation" MappingName="Explanation" HeaderTextAlignment="Center"
                                    LineBreakMode="WordWrap" ColumnWidthMode="FitByHeader"/>
                            </dataGrid:SfDataGrid.Columns>
                        </dataGrid:SfDataGrid>

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="20" Margin="10">
                            <Button Text="Previous" Command="{Binding PreviousPageCommand}" TextColor="#49454F" Background="#6750A4" FontSize="14"/>
                            <Label Text="{Binding PredictionPageInfo}" VerticalOptions="Center"/>
                            <Button Text="Next" Command="{Binding NextPageCommand}" TextColor="#49454F" Background="#6750A4" FontSize="14"/>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>

                </Grid>
            </Border>

            <Border Grid.Row="3" Stroke="#F7F2FB" Background="#FFFBFE" StrokeShape="RoundRectangle 8">
                <ScrollView HorizontalScrollBarVisibility="Always" VerticalScrollBarVisibility="Always">
                    <VerticalStackLayout>
                        <Label Text="AI Insights" FontAttributes="Bold" FontSize="14" Margin="10,0,0,10" FontFamily="RobotoMedium" TextColor="#49454F"/>
                        <Label Text="{Binding InsightsExplanation}" TextType="Html" FontSize="14" FontFamily="RobotoRegular" TextColor="#1C1B1F"/>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>

            <core:SfBusyIndicator Grid.Row="0" Grid.RowSpan="4" IsVisible="{Binding IsBusy}" x:Name="busyIndicator"
       IsRunning="{Binding IsBusy}" AnimationType="Cupertino" SizeFactor="0.8"/>
        </Grid>
    </ScrollView>

</ContentView>
