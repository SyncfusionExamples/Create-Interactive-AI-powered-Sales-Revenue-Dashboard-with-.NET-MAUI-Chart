<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             x:Class="AISalesDashboard.QuantityChart">

    <VerticalStackLayout Spacing="10" VerticalOptions="Center">

        <Label Text="Quantity Sold" FontSize="16" FontAttributes="Bold" Margin="15,10,0,0" TextColor="#1C1B1F"/>

        <chart:SfCartesianChart Margin="10">

            <chart:SfCartesianChart.XAxes>
                <chart:DateTimeAxis IntervalType="Days" ShowMajorGridLines="False" LabelCreated="DateTimeAxis_LabelCreated" AutoScrollingDelta="1" AutoScrollingMode="End" AutoScrollingDeltaType="Months">
                    <chart:DateTimeAxis.LabelStyle>
                        <chart:ChartAxisLabelStyle TextColor="#49454F"/>
                    </chart:DateTimeAxis.LabelStyle>
                    <chart:DateTimeAxis.AxisLineStyle>
                        <chart:ChartLineStyle Stroke="#CAC4D0"/>
                    </chart:DateTimeAxis.AxisLineStyle>
                </chart:DateTimeAxis>
            </chart:SfCartesianChart.XAxes>

            <chart:SfCartesianChart.YAxes>
                <chart:NumericalAxis EdgeLabelsDrawingMode="Center" PlotOffsetEnd="5" Minimum="0" Maximum="1000" Interval="250" LabelCreated="NumericalAxis_LabelCreated">
                    <chart:NumericalAxis.LabelStyle>
                        <chart:ChartAxisLabelStyle TextColor="#49454F"/>
                    </chart:NumericalAxis.LabelStyle>
                    <chart:NumericalAxis.MajorGridLineStyle>
                        <chart:ChartLineStyle Stroke="#E7E0EC"/>
                    </chart:NumericalAxis.MajorGridLineStyle>
                </chart:NumericalAxis>
            </chart:SfCartesianChart.YAxes>

            <chart:SfCartesianChart.ZoomPanBehavior>
                <chart:ChartZoomPanBehavior EnablePanning="True" EnablePinchZooming="False"/>
            </chart:SfCartesianChart.ZoomPanBehavior>

            <chart:ColumnSeries XBindingPath="Date" YBindingPath="Quantity" 
                ItemsSource="{Binding SalesData}" Width="0.7"
                Fill="#7442DD"/>
        </chart:SfCartesianChart>

    </VerticalStackLayout>

</ContentView>
